# llm-proxy v2 environment config
# Copy to .env and fill in values before deploying.

# ---------------------------------------------------------------------------
# Required
# ---------------------------------------------------------------------------

# Key that all clients (hermes, OpenWebUI, etc.) use to authenticate
# to the proxy. Set this to any strong secret string.
PROXY_API_KEY=

# ---------------------------------------------------------------------------
# Admin API (optional)
# If unset, all /admin/* endpoints return 404.
# ---------------------------------------------------------------------------
ADMIN_TOKEN=

# ---------------------------------------------------------------------------
# Tuning (all have defaults, override as needed)
# ---------------------------------------------------------------------------

# How often to refresh model lists from all backends (seconds)
# REFRESH_INTERVAL_SECONDS=60

# How many times to rescan a backend before returning 404 on a miss
# MISS_RETRY_ATTEMPTS=3

# Delay between miss retry attempts (seconds)
# MISS_RETRY_DELAY_SECONDS=2

# Timeout for backend /v1/models scan requests (seconds)
# BACKEND_SCAN_TIMEOUT=10

# Timeout for proxied inference requests (seconds)
# REQUEST_TIMEOUT=600

# Connection establishment timeout (seconds)
# REQUEST_CONNECT_TIMEOUT=10

# Log level: debug, info, warning, error
# LOG_LEVEL=info

# Port the proxy listens on
# PROXY_PORT=8000

# Path to config file (default works inside Docker; override for local runs)
# CONFIG_PATH=./config.yaml

# ---------------------------------------------------------------------------
# Per-backend API keys
# Reference these by name in config.yaml under api_key:
# ---------------------------------------------------------------------------

# EXTERNAL_API_KEY=
# SOME_OTHER_BACKEND_KEY=
